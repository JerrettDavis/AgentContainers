{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentcontainers.dev/schemas/common-tools.schema.json",
  "title": "Common Tools Manifest",
  "description": "Schema for AgentContainers common tools definitions (v1)",
  "type": "object",
  "required": ["id", "display_name", "version", "packages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "description": { "type": "string" },
    "packages": {
      "type": "object",
      "properties": {
        "apt": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "post_install": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "command": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "commands": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "additionalProperties": false
}
