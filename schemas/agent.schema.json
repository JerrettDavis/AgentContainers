{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentcontainers.dev/schemas/agent.schema.json",
  "title": "Agent Overlay Manifest",
  "description": "Schema for AgentContainers agent overlay definitions (v1)",
  "type": "object",
  "required": ["id", "display_name", "version", "install"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "display_name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "enum": ["v1"] },
    "description": { "type": "string" },
    "requires": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Capability tokens required from base/combo"
    },
    "conflicts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "install": {
      "type": "object",
      "required": ["method", "package"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["npm_global", "pip", "curl-to-bin", "apt"]
        },
        "package": { "type": "string" },
        "version": { "type": "string" },
        "post_install": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "default": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "sensitive": { "type": "boolean" },
          "inject_from": { "type": "string" }
        }
      }
    },
    "mounts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "container_path": { "type": "string" },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "suggested_host_path": { "type": "string" }
        }
      }
    },
    "healthcheck": {
      "type": "object",
      "properties": {
        "test": { "type": "array", "items": { "type": "string" } },
        "interval": { "type": "string" },
        "timeout": { "type": "string" },
        "retries": { "type": "integer" },
        "start_period": { "type": "string" }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "commands": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compose_capabilities": {
      "type": "object",
      "properties": {
        "service_name_default": { "type": "string" },
        "ports": { "type": "array", "items": { "type": "string" } },
        "networks": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "additionalProperties": false
}
