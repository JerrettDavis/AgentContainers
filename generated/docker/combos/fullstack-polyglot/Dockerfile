ARG PRIMARY_BASE_IMAGE=agentcontainers/node-bun:latest
ARG RUST_STAGE_IMAGE=agentcontainers/rust:latest
ARG PYTHON_STAGE_IMAGE=agentcontainers/python:latest
ARG DOTNET_STAGE_IMAGE=agentcontainers/dotnet:latest

FROM ${PRIMARY_BASE_IMAGE} AS runtime

FROM ${RUST_STAGE_IMAGE} AS rust_stage

FROM ${PYTHON_STAGE_IMAGE} AS python_stage

FROM ${DOTNET_STAGE_IMAGE} AS dotnet_stage

FROM runtime

# Combo: Full-Stack Polyglot
# Bases (ordered): node-bun → rust → python → dotnet

USER root

# --- Import runtime from Rust base ---
COPY --from=rust_stage /usr/local/cargo /usr/local/cargo
COPY --from=rust_stage /usr/local/rustup /usr/local/rustup
ENV CARGO_HOME=/usr/local/cargo
ENV RUSTUP_HOME=/usr/local/rustup
ENV PATH="/usr/local/cargo/bin:${PATH}"

# --- Rust runtime setup ---
# Install Rust toolchain components
RUN rustup component add clippy rustfmt rust-analyzer

# --- Import runtime from Python base ---
COPY --from=python_stage /usr/local /usr/local

# --- Python runtime setup ---
# Install pipx for isolated tool installs
RUN pip install --no-cache-dir --upgrade pip==26.0.1 pipx && \
    pipx ensurepath

# --- Import runtime from .NET SDK base ---
COPY --from=dotnet_stage /usr/share/dotnet /usr/share/dotnet
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    libicu-dev \
  && rm -rf /var/lib/apt/lists/*
RUN ln -sf /usr/share/dotnet/dotnet /usr/bin/dotnet

# --- .NET SDK runtime setup ---
# Configure dotnet CLI telemetry opt-out
RUN echo 'export DOTNET_CLI_TELEMETRY_OPTOUT=1' >> /etc/profile.d/dotnet.sh
# Remove inherited PowerShell runtime
RUN rm -f /usr/bin/pwsh && \
    rm -rf /usr/share/powershell

# Re-apply common tool path helpers
# Alias fd-find to fd
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd
# Ensure ripgrep is on PATH
RUN ln -sf /usr/bin/rg /usr/local/bin/rg || true

# Cross-runtime utilities
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    pipx \
    pkg-config \
    libssl-dev \
  && rm -rf /var/lib/apt/lists/*

USER dev

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
  CMD ["CMD-SHELL", "node --version || exit 1"]

