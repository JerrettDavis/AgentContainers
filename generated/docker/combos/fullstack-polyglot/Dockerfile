FROM node:22-bookworm-slim

# Combo: Full-Stack Polyglot
# Bases (ordered): node-bun → rust → python → dotnet

# --- Node.js + Bun runtime ---
# Install Bun
RUN curl -fsSL https://bun.sh/install | bash && \
    echo 'export BUN_INSTALL="$HOME/.bun"' >> /etc/profile.d/bun.sh && \
    echo 'export PATH="$HOME/.bun/bin:$PATH"' >> /etc/profile.d/bun.sh

# --- Rust runtime ---
# Install additional Rust development tools
RUN rustup component add clippy rustfmt rust-analyzer && \
    cargo install cargo-watch cargo-edit

# --- Python runtime ---
# Install pipx for isolated tool installs
RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

# --- .NET SDK runtime ---
# Configure dotnet CLI telemetry opt-out
RUN echo 'export DOTNET_CLI_TELEMETRY_OPTOUT=1' >> /etc/profile.d/dotnet.sh

# OCI Image Labels
ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
ARG IMAGE_VERSION=v1

LABEL org.opencontainers.image.title="Full-Stack Polyglot"
LABEL org.opencontainers.image.description="Node.js 22 + Bun + Rust + Python 3.12 + .NET — the works"
LABEL org.opencontainers.image.source="https://github.com/agentcontainers/AgentContainers"
LABEL org.opencontainers.image.url="https://github.com/agentcontainers/AgentContainers"
LABEL org.opencontainers.image.vendor="AgentContainers"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.version="${IMAGE_VERSION}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.revision="${VCS_REF}"
LABEL dev.agentcontainers.image-type="combo"
