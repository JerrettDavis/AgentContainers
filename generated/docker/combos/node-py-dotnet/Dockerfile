FROM node:22-bookworm-slim

# Combo: Node.js + Python + .NET
# Bases (ordered): node-bun → python → dotnet

# --- Node.js + Bun runtime ---
# Install Bun
RUN curl -fsSL https://bun.sh/install | bash && \
    echo 'export BUN_INSTALL="$HOME/.bun"' >> /etc/profile.d/bun.sh && \
    echo 'export PATH="$HOME/.bun/bin:$PATH"' >> /etc/profile.d/bun.sh

# --- Python runtime ---
# Install pipx for isolated tool installs
RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

# --- .NET SDK runtime ---
# Configure dotnet CLI telemetry opt-out
RUN echo 'export DOTNET_CLI_TELEMETRY_OPTOUT=1' >> /etc/profile.d/dotnet.sh

LABEL org.opencontainers.image.title="Node.js + Python + .NET"
LABEL org.opencontainers.image.description="Full-stack combo with Node.js 22, Python 3.12, and .NET 8"
