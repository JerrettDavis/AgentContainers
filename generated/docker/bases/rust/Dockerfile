FROM rust:1-slim-bookworm

# Layer 1: Common Tools
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    less \
    sudo \
    jq \
    nano \
    vim \
    unzip \
    gnupg2 \
    man-db \
    ripgrep \
    fd-find \
    procps \
    ca-certificates \
    bash-completion \
    zsh \
    tar \
    xz-utils \
    tree \
    htop \
    openssh-client \
  && rm -rf /var/lib/apt/lists/*

# Alias fd-find to fd
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd
# Ensure ripgrep is on PATH
RUN ln -sf /usr/bin/rg /usr/local/bin/rg || true

# Layer 2: Rust Runtime
# Install Rust toolchain components
RUN rustup component add clippy rustfmt rust-analyzer

# Environment defaults (override at build time with --build-arg)
ARG CARGO_HOME=/usr/local/cargo
ENV CARGO_HOME=${CARGO_HOME}
ARG RUSTUP_HOME=/usr/local/rustup
ENV RUSTUP_HOME=${RUSTUP_HOME}

# Ensure Rust toolchain binaries are on PATH for the runtime user
ENV PATH="/usr/local/cargo/bin:${PATH}"

# User setup
RUN groupadd -g 1000 dev 2>/dev/null || true \
  && useradd -m -u 1000 -g 1000 dev 2>/dev/null \
  || id -u dev >/dev/null 2>&1 \
  || (useradd -m -o -u 1000 -g 1000 dev)
RUN echo 'dev ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers.d/dev
USER dev

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD ["CMD", "rustc", "--version"]

# OCI Image Labels
ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
ARG IMAGE_VERSION=v1

