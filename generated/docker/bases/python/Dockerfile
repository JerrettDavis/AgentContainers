FROM python:3.12-slim-bookworm

# Layer 1: Common Tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    less \
    sudo \
    jq \
    nano \
    vim \
    unzip \
    gnupg2 \
    man-db \
    ripgrep \
    fd-find \
    procps \
    ca-certificates \
    bash-completion \
    zsh \
    tar \
    xz-utils \
    tree \
    htop \
    openssh-client
  && rm -rf /var/lib/apt/lists/*

# Alias fd-find to fd
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd
# Ensure ripgrep is on PATH
RUN ln -sf /usr/bin/rg /usr/local/bin/rg || true

# Layer 2: Python Runtime
# Install pipx for isolated tool installs
RUN pip install --no-cache-dir pipx && \
    pipx ensurepath

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# User setup
RUN groupadd -g 1000 dev \
  && useradd -m -u 1000 -g 1000 dev
RUN echo 'dev ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers.d/dev
USER dev

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD ["CMD", "python3", "--version"]

LABEL org.opencontainers.image.title="Python"
LABEL org.opencontainers.image.description="Python 3.12 with pip and venv"
LABEL dev.agentcontainers.runtime-family="python"
