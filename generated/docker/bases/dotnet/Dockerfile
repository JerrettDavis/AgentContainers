FROM mcr.microsoft.com/dotnet/sdk:10.0-noble

# Layer 1: Common Tools
RUN apt-get update && apt-get upgrade -y && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    less \
    sudo \
    jq \
    nano \
    vim \
    unzip \
    gnupg2 \
    man-db \
    ripgrep \
    fd-find \
    procps \
    ca-certificates \
    bash-completion \
    zsh \
    tar \
    xz-utils \
    tree \
    htop \
    openssh-client \
  && rm -rf /var/lib/apt/lists/*

# Alias fd-find to fd
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd
# Ensure ripgrep is on PATH
RUN ln -sf /usr/bin/rg /usr/local/bin/rg || true

# Layer 2: .NET SDK Runtime
# Configure dotnet CLI telemetry opt-out
RUN echo 'export DOTNET_CLI_TELEMETRY_OPTOUT=1' >> /etc/profile.d/dotnet.sh
# Remove inherited PowerShell runtime
RUN rm -f /usr/bin/pwsh && \
    rm -rf /usr/share/powershell

# Environment defaults (override at build time with --build-arg)
ARG DOTNET_CLI_TELEMETRY_OPTOUT=1
ENV DOTNET_CLI_TELEMETRY_OPTOUT=${DOTNET_CLI_TELEMETRY_OPTOUT}
ARG DOTNET_NOLOGO=1
ENV DOTNET_NOLOGO=${DOTNET_NOLOGO}

# User setup
RUN groupadd -g 1000 dev 2>/dev/null || true \
  && useradd -m -u 1000 -g 1000 dev 2>/dev/null \
  || id -u dev >/dev/null 2>&1 \
  || (useradd -m -o -u 1000 -g 1000 dev)
RUN echo 'dev ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers.d/dev
USER dev

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD ["CMD", "dotnet", "--version"]

# OCI Image Labels
ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
ARG IMAGE_VERSION=v1

LABEL org.opencontainers.image.title=".NET SDK"
LABEL org.opencontainers.image.description=".NET 10 SDK for C# and F# development"
LABEL org.opencontainers.image.source="https://github.com/agentcontainers/AgentContainers"
LABEL org.opencontainers.image.url="https://github.com/agentcontainers/AgentContainers"
LABEL org.opencontainers.image.vendor="AgentContainers"
LABEL org.opencontainers.image.licenses="MIT"
LABEL org.opencontainers.image.version="${IMAGE_VERSION}"
LABEL org.opencontainers.image.created="${BUILD_DATE}"
LABEL org.opencontainers.image.revision="${VCS_REF}"
LABEL dev.agentcontainers.runtime-family="dotnet"
LABEL dev.agentcontainers.image-type="base"
