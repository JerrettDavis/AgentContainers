FROM node:22-bookworm-slim

# Layer 1: Common Tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    wget \
    less \
    sudo \
    jq \
    nano \
    vim \
    unzip \
    gnupg2 \
    man-db \
    ripgrep \
    fd-find \
    procps \
    ca-certificates \
    bash-completion \
    zsh \
    tar \
    xz-utils \
    tree \
    htop \
    openssh-client \
  && rm -rf /var/lib/apt/lists/*

# Alias fd-find to fd
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd
# Ensure ripgrep is on PATH
RUN ln -sf /usr/bin/rg /usr/local/bin/rg || true

# Layer 2: Node.js + Bun Runtime
# Install Bun
RUN curl -fsSL https://bun.sh/install | bash && \
    echo 'export BUN_INSTALL="$HOME/.bun"' >> /etc/profile.d/bun.sh && \
    echo 'export PATH="$HOME/.bun/bin:$PATH"' >> /etc/profile.d/bun.sh

# Environment defaults (override at build time with --build-arg)
ARG NODE_ENV=development
ENV NODE_ENV=${NODE_ENV}
ARG BUN_INSTALL=/home/dev/.bun
ENV BUN_INSTALL=${BUN_INSTALL}

# User setup
RUN groupadd -g 1000 dev 2>/dev/null || true \
  && useradd -m -u 1000 -g 1000 dev 2>/dev/null \
  || id -u dev >/dev/null 2>&1 \
  || (useradd -m -o -u 1000 -g 1000 dev)
RUN echo 'dev ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers.d/dev
USER dev

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD ["CMD", "node", "--version"]

# OCI Image Labels
ARG BUILD_DATE=unknown
ARG VCS_REF=unknown
ARG IMAGE_VERSION=v1

LABEL org.opencontainers.image.title="Node.js + Bun"
