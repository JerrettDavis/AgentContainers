{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/AgentContainers.Core/AgentContainers.Core.csproj",
            "src/AgentContainers.Generator/AgentContainers.Generator.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "dest": "api",
      "shouldSkipMarkup": true,
      "disableDefaultFilter": false,
      "properties": {
        "Configuration": "Release",
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "articles/**/*.md",
          "articles/**/toc.yml",
          "ENV-CONTRACT.md",
          "e2e-testing.md",
          "plans/**/*.md",
          "plans/**/toc.yml",
          "api/**.yml",
          "api/**/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "AgentContainers Docs",
      "_appName": "AgentContainers",
      "_enableSearch": true,
      "_disableBreadcrumb": false,
      "_noindex": false
    }
  }
}
