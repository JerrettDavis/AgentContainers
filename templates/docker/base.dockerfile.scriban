# AUTO-GENERATED — do not edit by hand.
# Source: definitions/bases/{{ base.id }}.yaml
# Generated by AgentContainers.Generator

FROM {{ base.from.image }}

{{~ if common_tools ~}}
# Layer 1: Common Tools
RUN apt-get update && apt-get install -y --no-install-recommends \
{{~ for pkg in common_tools.packages.apt ~}}
    {{ pkg }} \
{{~ end ~}}
  && rm -rf /var/lib/apt/lists/*

{{~ for step in common_tools.post_install ~}}
# {{ step.description }}
RUN {{ step.command }}
{{~ end ~}}
{{~ end ~}}

# Layer 2: {{ base.display_name }} Runtime
{{~ for step in base.install.steps ~}}
# {{ step.description }}
RUN {{ step.run | string.strip }}
{{~ end ~}}

{{~ for env in base.env ~}}
{{~ if env.default && !env.sensitive ~}}
ENV {{ env.name }}={{ env.default }}
{{~ end ~}}
{{~ end ~}}

# User setup
RUN groupadd -g {{ base.user.gid }} {{ base.user.name }} \
  && useradd -m -u {{ base.user.uid }} -g {{ base.user.gid }} {{ base.user.name }}
{{~ if base.user.sudo ~}}
RUN echo '{{ base.user.name }} ALL=(ALL) NOPASSWD:ALL' >> /etc/sudoers.d/{{ base.user.name }}
{{~ end ~}}
USER {{ base.user.name }}

{{~ if base.healthcheck.test.size > 0 ~}}
HEALTHCHECK --interval={{ base.healthcheck.interval }} --timeout={{ base.healthcheck.timeout }} --retries={{ base.healthcheck.retries }} \
  CMD [{{ base.healthcheck.test | array.join '", "' | prepend '"' | append '"' }}]
{{~ end ~}}

LABEL org.opencontainers.image.title="{{ base.display_name }}"
LABEL org.opencontainers.image.description="{{ base.description }}"
LABEL dev.agentcontainers.runtime-family="{{ base.family }}"
